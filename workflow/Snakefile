from pathlib import Path
import json

DATA_DIR = Path(config.get("data_dir", "data"))
ZSTD_DATA_DIR = Path(config.get("zstd_data_dir", "data/zstd"))
TEMPERATURE_ADC_SUM_CONFIG = Path(config.get("temperature_adc_sum_config", "config/temperature_adc_sum_comparison_2026_07_05.json"))


def raw_path_for_run(wildcards):
    run_name = f"{wildcards.run}.raw"
    zstd_name = f"{run_name}.zst"
    candidates = [
        ZSTD_DATA_DIR / zstd_name,
        DATA_DIR / "zstd" / zstd_name,
        DATA_DIR / zstd_name,
        DATA_DIR / run_name,
        Path("data") / run_name,
        Path(run_name),
    ]
    for candidate in candidates:
        if candidate.exists():
            return str(candidate)
    return str(candidates[0])


def verification_marker_for_run(wildcards):
    if raw_path_for_run(wildcards).endswith(".raw.zst"):
        return f"dump/verified_zstd/{wildcards.run}.done"
    return []


def run_name_from_zstd_raw(path):
    return path.name[:-len(".raw.zst")]


def has_nonempty_checksum_sidecar(path):
    checksum_path = Path(f"{path}.sha256")
    if not checksum_path.is_file():
        return False
    try:
        fields = {
            label: value
            for value, label in (
                line.rstrip("\n").split("  ", 1)
                for line in checksum_path.read_text().splitlines()
            )
        }
        return int(fields.get("original_size", "0")) > 0
    except (OSError, ValueError):
        return False


VERIFIED_ZSTD_RUNS = sorted(
    run_name_from_zstd_raw(path)
    for path in ZSTD_DATA_DIR.glob("*.raw.zst")
    if not path.name.startswith("._") and has_nonempty_checksum_sidecar(path)
)


RAW_RUNS = sorted(
    run_name_from_zstd_raw(path)
    for path in ZSTD_DATA_DIR.glob("*.raw.zst")
    if not path.name.startswith("._")
)
if not RAW_RUNS and ZSTD_DATA_DIR != DATA_DIR / "zstd":
    RAW_RUNS = sorted(
        run_name_from_zstd_raw(path)
        for path in (DATA_DIR / "zstd").glob("*.raw.zst")
        if not path.name.startswith("._")
    )
if not RAW_RUNS:
    RAW_RUNS = sorted(
        path.stem
        for path in DATA_DIR.glob("*.raw")
        if not path.name.startswith("._")
    )
if not RAW_RUNS and DATA_DIR != Path("data"):
    RAW_RUNS = sorted(
        path.stem
        for path in Path("data").glob("*.raw")
        if not path.name.startswith("._")
    )

ROOTIFIED_RUNS = sorted(
    path.parent.name[:-4]
    for path in Path("dump/001").glob("*.raw/sample_events.root")
    if path.parent.name.endswith(".raw")
)

SIZE_LIMIT = config.get("size_limit", "")
CRC = bool(config.get("crc", True))
SIZE_ARG = f"--size {SIZE_LIMIT}" if SIZE_LIMIT else ""
CRC_ARG = "--crc" if CRC else ""
TASK_MEM_MB = int(config.get("task_mem_mb", 4000))


def normalize_run_name(run):
    name = str(run).strip()
    if name.endswith(".raw.zst"):
        return name[:-len(".raw.zst")]
    if name.endswith(".raw"):
        return name[:-len(".raw")]
    return name


configured_single_run_adc_runs = config.get("single_run_adc_runs", [])
if isinstance(configured_single_run_adc_runs, str):
    configured_single_run_adc_runs = configured_single_run_adc_runs.split(",")
SINGLE_RUN_ADC_RUNS = sorted({
    normalize_run_name(run)
    for run in configured_single_run_adc_runs
    if str(run).strip()
})


def load_comparison_config(path):
    with open(path) as handle:
        return json.load(handle)


def histogram_path_from_raw(raw_path):
    return f"dump/002/{Path(raw_path).name}/event_adc_sum_histograms.root"


def tot_histogram_path_from_raw(raw_path):
    return f"dump/005/{Path(raw_path).name}/event_tot_sum_histograms.root"


def histogram_paths_from_comparison_config(path):
    comparison_config = load_comparison_config(path)
    roots = []
    for entry in comparison_config.get("entries", []):
        if "histogram" in entry:
            roots.append(entry["histogram"])
        elif "raw" in entry:
            roots.append(histogram_path_from_raw(entry["raw"]))
        else:
            raise ValueError(f"comparison config entry in {path} needs raw or histogram")
    return list(dict.fromkeys(roots))


def tot_histogram_paths_from_comparison_config(path):
    comparison_config = load_comparison_config(path)
    roots = []
    for entry in comparison_config.get("entries", []):
        if "histogram" in entry:
            roots.append(entry["histogram"])
        elif "raw" in entry:
            roots.append(tot_histogram_path_from_raw(entry["raw"]))
        else:
            raise ValueError(f"comparison config entry in {path} needs raw or histogram")
    return list(dict.fromkeys(roots))


def output_path_from_comparison_config(path, default_output):
    comparison_config = load_comparison_config(path)
    return comparison_config.get("output", default_output)


TEMPERATURE_ADC_SUM_ROOTS = histogram_paths_from_comparison_config(TEMPERATURE_ADC_SUM_CONFIG)
TEMPERATURE_ADC_SUM_OUTPUT = output_path_from_comparison_config(
    TEMPERATURE_ADC_SUM_CONFIG,
    "dump/003/temperature_adc_sum_comparison.pdf",
)


def is_003_comparison_config(path):
    try:
        comparison_config = load_comparison_config(path)
    except Exception as error:
        print(f"Skipping malformed 003 config candidate {path}: {error}")
        return False
    if not isinstance(comparison_config.get("entries"), list) or not comparison_config["entries"]:
        return False
    if not comparison_config.get("output"):
        return False
    return all("raw" in entry or "histogram" in entry for entry in comparison_config["entries"])


ADC_SUM_CONFIGS = sorted(
    path
    for path in Path("config").glob("*.json")
    if not path.name.startswith("._") and is_003_comparison_config(path)
)
ADC_SUM_CONFIG_BY_STEM = {path.stem: path for path in ADC_SUM_CONFIGS}
ADC_SUM_CONFIG_OUTPUTS = [output_path_from_comparison_config(path, f"dump/003/{path.stem}.pdf") for path in ADC_SUM_CONFIGS]
ADC_SUM_CONFIG_MARKERS = expand("dump/003/config_runs/{config_stem}.done", config_stem=ADC_SUM_CONFIG_BY_STEM.keys())
TOT_SUM_CONFIG_OUTPUTS = expand("dump/006/{config_stem}.pdf", config_stem=ADC_SUM_CONFIG_BY_STEM.keys())
TOT_SUM_CONFIG_MARKERS = expand("dump/006/config_runs/{config_stem}.done", config_stem=ADC_SUM_CONFIG_BY_STEM.keys())


def config_path_for_stem(wildcards):
    return str(ADC_SUM_CONFIG_BY_STEM[wildcards.config_stem.strip()])


def roots_for_config_stem(wildcards):
    return histogram_paths_from_comparison_config(ADC_SUM_CONFIG_BY_STEM[wildcards.config_stem.strip()])


def tot_roots_for_config_stem(wildcards):
    return tot_histogram_paths_from_comparison_config(ADC_SUM_CONFIG_BY_STEM[wildcards.config_stem.strip()])


def output_for_config_stem(wildcards):
    config_stem = wildcards.config_stem.strip()
    return output_path_from_comparison_config(ADC_SUM_CONFIG_BY_STEM[config_stem], f"dump/003/{config_stem}.pdf")


def tot_output_for_config_stem(wildcards):
    return f"dump/006/{wildcards.config_stem.strip()}.pdf"


