rule verify_zstd_raw:
    input:
        zst=lambda wildcards: str(ZSTD_DATA_DIR / f"{wildcards.run}.raw.zst"),
        checksum=lambda wildcards: str(ZSTD_DATA_DIR / f"{wildcards.run}.raw.zst.sha256")
    output:
        touch("dump/verified_zstd/{run}.done")
    log:
        "dump/logs/verify_zstd/{run}.log"
    resources:
        mem_mb=TASK_MEM_MB
    shell:
        r"""
        mkdir -p "$(dirname {output})" "$(dirname {log})"
        (
            stored_original=$(awk -F'  ' '$2 == "original" {{print $1}}' "{input.checksum}")
            stored_decompressed=$(awk -F'  ' '$2 == "decompressed" {{print $1}}' "{input.checksum}")
            stored_original_size=$(awk -F'  ' '$2 == "original_size" {{print $1}}' "{input.checksum}")
            stored_compressed_size=$(awk -F'  ' '$2 == "compressed_size" {{print $1}}' "{input.checksum}")
            actual_compressed_size=$(stat -c '%s' "{input.zst}")
            test -n "$stored_original"
            test "$stored_original" = "$stored_decompressed"
            if test "$stored_original_size" -le 0; then
                echo "cannot rootify empty raw stream: {input.zst}" >&2
                exit 1
            fi
            test "$stored_compressed_size" = "$actual_compressed_size"
            zstd -t -- "{input.zst}"
            actual_decompressed=$(zstd -dc -- "{input.zst}" | sha256sum | awk '{{print $1}}')
            test "$actual_decompressed" = "$stored_decompressed"
            echo "verified {input.zst}"
        ) > "{log}" 2>&1
        """


rule rootify:
    input:
        raw=raw_path_for_run,
        verified=verification_marker_for_run,
        exe=ancient("build/bin/001_Rootifier")
    output:
        root="dump/001/{run}.raw/sample_events.root",
        pdf="dump/001/{run}.raw/pt_line_type_distributions.pdf"
    log:
        "dump/logs/001/{run}.log"
    resources:
        mem_mb=TASK_MEM_MB
    shell:
        "mkdir -p $(dirname {log}) && "
        "{input.exe} --ignore-sample-timestamp --ignore-sample-cluster-timestamp --drop-failed-sample-candidate --input \"{input.raw}\" {SIZE_ARG} {CRC_ARG} --recon > {log} 2>&1"


