        mem_mb=TASK_MEM_MB
    shell:
        "mkdir -p \"$(dirname \"{log}\")\" && "
        "mkdir -p \"$(dirname \"{output.marker}\")\" && "
        "{input.exe} --config \"{input.config}\" > \"{log}\" 2>&1 && "
        "pdf=$(python3 -c 'import json, sys; config=json.load(open(sys.argv[1])); print(config.get(\"output\", \"dump/003/\" + sys.argv[2] + \".pdf\"))' \"{input.config}\" \"{wildcards.config_stem}\") && "
        "test -s \"$pdf\" && touch \"{output.marker}\""


